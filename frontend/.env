# .env – Environment Variables für das React-Frontend
#
# Good Practice: Sensible Daten wie Benutzername und Passwort sollten nie
# hartcodiert im Source-Code stehen. Mit Vite werden Variablen, die mit
# VITE_ beginnen, automatisch in den Client-Code injiziert.
#
# Wichtig zu wissen: Diese Datei wird von Vite automatisch geladen. Sie liegt
# im .gitignore, sodass sie nicht ins Git-Repository gelangt.

VITE_API_USERNAME=user
VITE_API_PASSWORD=password